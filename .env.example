# Last Minute Study Buddy — Environment Variables
# Copy this file to .env and fill in values if needed
# Currently this app needs NO environment variables
# Everything runs locally (Ollama + Streamlit)

# Ollama settings (defaults shown)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:3b

# Streamlit settings (optional)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
